# Backend – copy to .env and fill values.
# For Vercel: set all vars in Project Settings → Environment Variables.
# Required for Vercel: FRONTEND_URL or CORS_ORIGINS, FIREBASE_SERVICE_ACCOUNT_JSON (not PATH), CRON_SECRET.
PORT=3001
JWT_SECRET=your-secret-change-in-production
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:3001

# CORS – comma-separated origins allowed to call the API (no hardcoded URLs).
# Examples: http://localhost:5173, https://your-frontend.vercel.app, http://your-ec2-ip:8080
CORS_ORIGINS=

# Admin panel (EC2/same server on port 8080). When set, allows admin UI origin for CORS.
# Example: ADMIN_PANEL_ORIGIN=http://51.21.199.32:8080
# If PLATFORM_URL is set (e.g. http://51.21.199.32), admin origin http://51.21.199.32:8080 is allowed automatically.
ADMIN_PANEL_ORIGIN=

# RPC (Alchemy, Infura, or public BSC)
RPC_URL=
BOT_STATS_RPC_URL=

# Contract addresses (BSC)
USDT_ADDRESS=
SUBSCRIPTION_CONTRACT_ADDRESS=
NFT_CONTRACT_ADDRESS=
MARKETPLACE_CONTRACT_ADDRESS=
REFERRAL_CONTRACT_ADDRESS=
RESERVE_POOL_CONTRACT_ADDRESS=
CREATOR_WALLET=

# Bot addresses (for admin panel)
BOT_1_ADDRESS=
BOT_2_ADDRESS=

# NFT metadata
NFT_METADATA_BASE_URI=
NFT_MP4_CID=
IPFS_GATEWAY=
IPFS_GATEWAY_KEY=
PINATA_API_KEY=
PINATA_API_SECRET=
PINATA_JWT=

# PostgreSQL (RDS) – primary database when set. All app data uses PG; Firestore is fallback when PG unset.
# Production/EC2: set these so the platform runs on PostgreSQL. RDS requires SSL (default on).
PGHOST=
PGPORT=5432
PGDATABASE=
PGUSER=
PGPASSWORD=
# Optional: set PGSSL=false for local Postgres without SSL
# PGSSL=false

# Firebase – optional when PGHOST is set (used as fallback or for legacy /auth/firebase)
# PATH: local file path. JSON: raw JSON string (required on Vercel – no file access)
FIREBASE_SERVICE_ACCOUNT_PATH=./keys/your-firebase-adminsdk.json
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
FIREBASE_STORAGE_BUCKET=

# Indexer blocks (from block explorer)
REFERRAL_INDEXER_FROM_BLOCK=
MARKETPLACE_INDEXER_FROM_BLOCK=
BOT_STATS_FROM_BLOCK=

# Telegram (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Cron (Vercel Cron Jobs – set a strong random secret)
# Vercel sends Authorization: Bearer <CRON_SECRET> when triggering cron paths
CRON_SECRET=
