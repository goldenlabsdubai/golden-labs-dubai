# Golden Labs Admin Panel – copy to .env and set values.
# Admin does NOT use Firebase directly; it calls the backend API. Backend .env has Firebase + admins.
#
# Backend API (must match backend PORT and host). Local: http://localhost:3001/api
# On EC2: http://YOUR_SERVER_IP:3001/api (e.g. http://51.21.199.32:3001/api)
VITE_API_URL=http://localhost:3001/api

# Reown (WalletConnect) project ID – https://dashboard.reown.com (same as main platform)
VITE_PROJECT_ID=

# RPCs (optional – defaults work). Use same as platform for testnet/mainnet.
# VITE_BSC_RPC_URL=https://bsc-dataseed.binance.org/
# VITE_BSC_TESTNET_RPC_URL=https://bnb-testnet.g.alchemy.com/v2/YOUR_KEY

# Contracts page – optional if backend already has addresses
# VITE_SUBSCRIPTION_CONTRACT_ADDRESS=
# VITE_NFT_CONTRACT_ADDRESS=
# VITE_MARKETPLACE_CONTRACT_ADDRESS=
# VITE_REFERRAL_CONTRACT_ADDRESS=

# Bots page tuning (optional)
# VITE_BOTS_REFRESH_MS=20000
# VITE_BOTS_REQUEST_TIMEOUT_MS=20000
