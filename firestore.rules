rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Users: doc ID is wallet (lowercase) or firebase_uid. Each user can read/write only their own doc when using Firebase Auth UID.
    // Note: Top Sellers are read by the backend (Firebase Admin SDK), which bypasses these rules. The API GET /api/top-sellers uses Admin SDK to query users by totalTrades.
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Leaderboard: optional single doc (e.g. "top10") that backend can write with top sellers. Public read so landing page can fetch from client if desired.
    match /leaderboard/{docId} {
      allow read: if true;
      allow write: if false;
    }

    // Optional: profiles cache (same as users)
    match /profiles/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Deny everything else by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
